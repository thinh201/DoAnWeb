@using DoAnWeb.Models;
@using DoAnWeb.Utilities;
@model IList<Post>;
<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 heading-section text-center ftco-animate">
                <span class="subheading">Tin Tức</span>
                <h2> Tin Tức</h2>
            </div>
        </div>
        <div class="row d-flex">
            @foreach (var item in Model)
            {
                string url = Functions.TitleSlugGeneration("post", item.Title, item.PostId);

                <div class="col-md-4 d-flex ftco-animate">
                    <div class="blog-entry">
                        <a href="blog-single.html" class="block-20" style="background-image: url('@item.Images');">
                        </a>
                        <div class="text pt-4">
                            <div class="meta mb-3">
                                <div><a href="#">@item.CreatedDate.ToString("dd-MM-yyyy")</a></div>
                                <div><a href="#">@item.Author</a></div>
                                <div><a href="#" class="meta-chat"><span class="icon-chat"></span> 3</a></div>
                            </div>
                            <h3 class="heading mt-2"><a href="#">@item.Title</a></h3>
                            <p><a href="/@url" class="btn btn-primary">xem them</a></p>
                        </div>
                    </div>
                </div>
                // code cu 

               
            }
    </div>
</section>